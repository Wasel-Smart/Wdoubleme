# ── Supabase (required) ────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_EDGE_FUNCTION_NAME=make-server-0b1f4071
# Optional overrides when your API is not hosted at /functions/v1/<name>
# VITE_EDGE_FUNCTIONS_BASE_URL=https://your-project.supabase.co/functions/v1
# VITE_API_URL=https://api.example.com

# ── Google Maps (required for WaselMap) ────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Google OAuth (required for social sign-in) ─────────────────
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_SUPPORT_WHATSAPP_NUMBER=962790000000
VITE_AUTH_CALLBACK_PATH=/app/auth/callback

# ── Stripe (required for payments) ─────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Firebase (required for push notifications) ─────────────────
# Browser notifications use the Web Notifications API and the app service worker.
# No Firebase client environment variables are required for the current frontend flow.

# ── Sentry (optional — error monitoring) ───────────────────────
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ── App config ─────────────────────────────────────────────────
VITE_APP_URL=https://wasel14.online
VITE_APP_NAME=Wasel

# ── Feature flags (set to false in production) ─────────────────
VITE_ENABLE_DEMO_DATA=false
VITE_ENABLE_SYNTHETIC_TRIPS=false
